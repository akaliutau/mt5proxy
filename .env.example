# Local/dev defaults. Override for GCP VM deployment through instance/env secret management.
API_KEY=dev-api-key
TRADING_ENABLED=false
VNC_PASSWORD=

# MT5 credentials are optional. If left empty, log in through noVNC.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

MT5_TEST_SYMBOL=EURUSD
MT5_TEST_VOLUME=0.01
MT5LINUX_TIMEOUT=300
MT5_TIMEOUT_MS=60000
MT5_AUTOINSTALL=true
BASE_IMAGE=ubuntu:22.04

# Build-time WineHQ settings. Keep jammy for Ubuntu 22.04 base image.
WINEHQ_UBUNTU_CODENAME=jammy
WINEHQ_PACKAGE=winehq-staging
READY_MT5_TIMEOUT_MS=15000
BRIDGE_INIT_RETRY_SECONDS=60
BRIDGE_INIT_TIMEOUT_SECONDS=120
