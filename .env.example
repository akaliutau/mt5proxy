# Host may be Ubuntu 24.04. Container default is Ubuntu 22.04 for Wine stability.
BASE_IMAGE=ubuntu:22.04

# Browser desktop login. Ports are bound to 127.0.0.1 by compose.
VNC_PASSWORD=change-me-now

# API.
API_KEY=dev-api-key
TRADING_ENABLED=false

# First run: true attempts automatic mt5setup.exe /auto installation.
# Set false if you want to run the installer manually from noVNC.
MT5_AUTOINSTALL=true

# Optional broker login. You can also login manually from the MT5 GUI.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

MT5_TEST_SYMBOL=EURUSD
MT5_TEST_VOLUME=0.01
