# Local host port mappings. Keep these bound to 127.0.0.1 in docker-compose.yml for GCP VM safety.
NOVNC_HOST_PORT=3000
VNC_HOST_PORT=5900
API_HOST_PORT=8000
BRIDGE_HOST_PORT=8001

# Change before exposing beyond a localhost SSH tunnel.
API_KEY=dev-api-key
VNC_PASSWORD=

# MT5 account. Use demo credentials for automated testing and mutation tests.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TEST_SYMBOL=EURUSD
MT5_TEST_VOLUME=0.01

# Runtime behavior.
TRADING_ENABLED=false
MT5_AUTOINSTALL=true
MT5_CMD_OPTIONS=
MT5_TIMEOUT_MS=60000
MT5LINUX_HOST=127.0.0.1
MT5LINUX_BIND_HOST=0.0.0.0
MT5LINUX_PORT=8001
MT5LINUX_TIMEOUT=300
MT5_CONNECT_RETRIES=3
MT5_CONNECT_RETRY_DELAY=2

# Supervisor/watchdog tuning.
HEALTHWATCH_INTERVAL=30
HEALTHWATCH_START_PERIOD=90
HEALTHWATCH_RESTART_COOLDOWN=120
MT5_BOOTSTRAP_INTERVAL=300
MT5_WATCH_INTERVAL=20
INSTALL_WINE_PYTHON_TIMEOUT=900
MT5_INSTALL_TIMEOUT=600
BRIDGE_START_TIMEOUT=45

# Build options.
BASE_IMAGE=ubuntu:22.04
IMAGE_NAME=mt5proxy:local
CONTAINER_NAME=mt5-proxy
INSTALL_WINE_PYTHON_AT_BUILD=true
SHM_SIZE=1gb
