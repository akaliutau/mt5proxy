# Local host port mappings. Keep these bound to 127.0.0.1 in docker-compose.yml for GCP VM safety.
NOVNC_HOST_PORT=3000
VNC_HOST_PORT=5900
API_HOST_PORT=8000
BRIDGE_HOST_PORT=8001

API_KEY=dev-api-key
TRADING_ENABLED=true
MT5LINUX_HOST=127.0.0.1
MT5LINUX_PORT=8001
MT5LINUX_TIMEOUT=1000
MT5_TIMEOUT_MS=90000
MT5_TEST_SYMBOL=EURUSD
MT5_TEST_VOLUME=0.01
MT5_AUTOINSTALL=true

VNC_PASSWORD=
# Optional: MT5 login automation. Leave empty if you log in manually through noVNC.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=MetaQuotes-Demo



