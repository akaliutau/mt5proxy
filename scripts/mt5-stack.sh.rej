-main() {
+
+# Bridge startup is supervised separately by mt5-bridge-watch.sh. Keeping it as
+# its own supervisor program makes failures visible and lets supervisor restart
+# only the bridge without resetting the whole MT5 bootstrap stack.
+
+bootstrap_once() {
   wait_for_x || true
-  init_wine
+  init_wine || true
   install_mono || true
